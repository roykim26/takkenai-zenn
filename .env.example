# =========================
# 基础运行
# =========================
TIMEZONE=Asia/Tokyo
PUBLISH_START_HOUR=10
PUBLISH_START_MINUTE=0
TARGET_PLATFORM=all

# =========================
# Feishu Base
# =========================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_NOTIFY_CHAT_ID=

# =========================
# Qwen / DashScope
# =========================
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_TEMPERATURE=0.7

# Optional fallback for old Moonshot / Kimi config.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5
MOONSHOT_TEMPERATURE=0.7

# =========================
# 文章生成质量控制
# =========================
ARTICLE_MIN_BODY_CHARS=1200
ARTICLE_MIN_BODY_CHARS_ZENN=1400
ARTICLE_MIN_BODY_CHARS_HATENA=900
ARTICLE_MAX_TOKENS=3200
ARTICLE_MAX_KEYWORD_LINKS=3
HOMEPAGE_URL=https://www.takkenai.jp/
# retry_manager.py reads this value; invalid values fall back to 3.
ARTICLE_MAX_QUALITY_RETRY=3
HATENA_PUBLISH_MAX_RETRY=3

# =========================
# Zenn / Git
# =========================
ZENN_REPO_PATH=E:\yanque\海外投放\zen\takkenai-zenn
GIT_REMOTE=origin
GIT_BRANCH=main
GIT_PUSH_RETRY_TIMES=3

# =========================
# Zenn 配额保护
# =========================
PUBLISH_GATE_FILE=publish_control.json
GATE_TOTAL_DAILY_PUSH_LIMIT=1
GATE_NEW_DAILY_PUSH_LIMIT=1
GATE_RETRY_COOLDOWN_HOURS=24
GATE_RETRY_DAILY_LIMIT_PER_SLUG=1

# =========================
# Hatena
# =========================
HATENA_ID=
HATENA_BLOG_ID=
HATENA_API_KEY=
HATENA_BASE_URL=https://blog.hatena.ne.jp
HATENA_CONTENT_TYPE=text/plain
HATENA_DEFAULT_DRAFT=no
HATENA_ENABLE_CUSTOM_URL=true
HATENA_ENABLE_PREVIEW=no
HATENA_USE_SCHEDULED=no
HATENA_CATEGORY_SOURCE=keywords
HATENA_EXPORT_DIR=hatena_exports

# Hatena account B. Leave empty unless Feishu hatena_account is set to B.
HATENA_ACCOUNT_B_ID=
HATENA_ACCOUNT_B_BLOG_ID=
HATENA_ACCOUNT_B_API_KEY=
HATENA_ACCOUNT_B_BASE_URL=https://blog.hatena.ne.jp
HATENA_ACCOUNT_B_EXPORT_DIR=hatena_exports_b

# =========================
# 飞书字段映射
# =========================
FIELD_TITLE=topic
FIELD_PROMPT=brief
FIELD_KEYWORDS=keywords
FIELD_PLATFORM=platform
FIELD_PUBLISH_DATE=publish_date
FIELD_STATUS=status
FIELD_SLUG=slug
FIELD_IMAGE_PROMPT=image_prompt
FIELD_ANCHOR_LINKS=anchor_links
FIELD_CATEGORIES=categories
FIELD_IS_DRAFT=is_draft
FIELD_HATENA_ACCOUNT=hatena_account

# =========================
# 飞书回写字段映射
# =========================
WRITE_FIELD_STATUS=status
WRITE_FIELD_SLUG=slug
WRITE_FIELD_ARTICLE_TITLE=article_title
WRITE_FIELD_ARTICLE_EXCERPT=article_excerpt
WRITE_FIELD_ARTICLE_PATH=article_path
WRITE_FIELD_ARTICLE_URL=article_url
WRITE_FIELD_EDIT_URL=edit_url
WRITE_FIELD_PLATFORM_POST_ID=platform_post_id
WRITE_FIELD_PUBLISHED_AT=published_at
WRITE_FIELD_LAST_PUSH_AT=last_push_at
WRITE_FIELD_LAST_RESULT=last_result
WRITE_FIELD_RETRY_COUNT=retry_count
WRITE_FIELD_ERROR_MESSAGE=error_message

# =========================
# 状态值
# =========================
STATUS_READY=ready
STATUS_PUBLISHING=publishing
STATUS_QUEUED=queued
STATUS_WAITING=waiting
STATUS_PUBLISHED=published
STATUS_FAILED=failed


# =========================
# OpenAI 生图相关变量
# =========================
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
